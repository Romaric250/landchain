# Core
ENV=development
FRONTEND_URL=https://lanchain.land
CORS_ORIGINS=http://localhost:3000,https://lanchain.land,https://www.lanchain.land

# Auth / JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=30

# Database
MONGO_URI=mongodb://localhost:27017/landchain

# Email — Resend (leave empty in dev: emails are logged instead of sent)
RESEND_API_KEY=
EMAIL_FROM=LandChain <noreply@landchain.app>
# Public logo URL for HTML emails (UploadThing / CDN — must be HTTPS)
EMAIL_LOGO_URL=https://bouvzl2icp.ufs.sh/f/OymSP2c12cOMFdwVHZGO54b7HVQ6KiX3LatyEeDZrMm1wWoF

# Payments — Fapshi (leave empty in dev: mock checkout mode is used)
FAPSHI_BASE_URL=https://sandbox.fapshi.com
FAPSHI_API_USER=
FAPSHI_API_KEY=
FAPSHI_WEBHOOK_SECRET=

# Pricing (XAF) — placeholders, confirm before launch
PRICE_SUBSCRIPTION_MONTHLY=2000
PRICE_SUBSCRIPTION_QUARTERLY=5000
PRICE_SUBSCRIPTION_ANNUAL=18000
PRICE_LISTING_FEE=5000
LISTING_DURATION_DAYS=60

# File storage — UploadThing (leave empty in dev: any https URL accepted)
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=

# Maps
MAPBOX_ACCESS_TOKEN=

# Blockchain — Polygon (leave empty in dev: records anchored off-chain only)
POLYGON_RPC_URL=
LANDREGISTRY_CONTRACT_ADDRESS=
DEPLOYER_PRIVATE_KEY=

# AI — Google Gemini vision (recommended). Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Legacy: custom inference service base URL (only used when GEMINI_API_KEY is empty)
AI_MODEL_ENDPOINT=

# Cache / rate limiting (optional; in-memory fallback used when empty)
REDIS_URL=

# Bootstrap super admin (created at first startup)
SUPER_ADMIN_EMAIL=admin@landchain.app
SUPER_ADMIN_PASSWORD=ChangeMe123!

# Seed 20 demo parcels on startup (for map/marketplace demo)
SEED_DEMO_DATA=true
